# LifeLensAI Cloud Configuration Template
# Duplicate this file to .env and fill in your production secrets

# --- DATABASE (MongoDB Atlas) ---
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=lifelens

# --- SECURITY ---
# Generate a strong key using: openssl rand -hex 32
JWT_SECRET=super-secret-key-lifelens-change-in-production

# --- DEPLOYMENT (Render/Vercel) ---
# Comma-separated list of allowed origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,https://your-app-name.vercel.app

# --- OPTIONAL: EXTERNAL AI SERVICES ---
GEMINI_API_KEY=your-google-gemini-api-key-here
